{
  "installCommand": "npm ci --include=optional && npm install @rolldown/binding-linux-x64-gnu@1.0.3 --no-save",
  "buildCommand": "npm run build:edgeone",
  "outputDirectory": "dist",
  "nodeVersion": "22.11.0",
  "cloudFunctions": {
    "nodejs": {
      "maxDuration": 120
    }
  },
  "redirects": [
    { "source": "/life", "destination": "/#/life", "statusCode": 302 },
    { "source": "/travel", "destination": "/#/travel", "statusCode": 302 },
    { "source": "/wealth", "destination": "/#/wealth", "statusCode": 302 },
    { "source": "/gallery", "destination": "/#/gallery", "statusCode": 302 }
  ]
}
