{
  "fluid": true,
  "functions": {
    "api/travel-plan.js": {
      "maxDuration": 300
    },
    "api/travel-plan-stream.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
